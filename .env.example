# Chave do Groq (usada pelo LangGraph e pelo CrewAI quando em modo Groq)
GROQ_API_KEY="coloque_sua_chave_groq_aqui"

# Chave do Google Gemini (usada pelo CrewAI para LLM + embeddings de memória)
GOOGLE_GEMINI_KEY="coloque_sua_chave_gemini_aqui"

# ─── Motor de Execução ───────────────────────────────────────────────────────
# Seleciona qual framework de IA processa as mensagens do chat.
# Opções:
#   crewai    → Equipe multiagente com CrewAI + Google Gemini (padrão recomendado)
#   langgraph → Grafo de estado determinístico com LangGraph + Groq (implementação legada)
AGENT_ENGINE=crewai
